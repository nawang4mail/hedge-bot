# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b          # swap for mistral, codestral, etc.

# ── Market Data ───────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper trading endpoint

NEWS_API_KEY=your_newsapi_key

# ── Risk Defaults (overridable via UI) ───────────────────────────────────────
MAX_POSITION_PCT=0.05          # max 5 % of portfolio per trade
MAX_PORTFOLIO_RISK_PCT=0.20    # halt if drawdown exceeds 20 %
DEFAULT_ORDER_TYPE=limit       # limit | market

# ── TimescaleDB ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password   # used by docker-compose and DATABASE_URL
DATABASE_URL=postgresql://hedge:change_me_strong_password@localhost:5432/hedgebot

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── API authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (dev only — never empty in production).
API_KEY=
